# Alchemy Rails — example environment file.
# Copy to `.env` and fill in the values relevant for your environment.

# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost:5432/alchemy_development
REDIS_URL=redis://localhost:6379/0
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=info
PORT=3200

# Shared secret used to encode agt_/tsk_/cnv_ public_ids (prefixed_ids gem).
# Falls back to Rails.application.secret_key_base if unset. For production,
# set this to a dedicated random 32+ char value so the encoding is stable
# across secret_key_base rotations.
PREFIXED_IDS_SALT=

# ─── Engine bridge ───────────────────────────────────────────────────────────
# URL of the running alchemy_engine gateway (per-agent HTTP + WebSocket).
ENGINE_URL=http://localhost:3300

# Shared secret between Rails and engine for /api/blobs, /api/task_events,
# and EngineSync POST /sync. Must match ENGINE_API_SECRET in engine `.env`.
ENGINE_API_SECRET=

# Public base URL used when registering webhooks (Twilio, SES). In dev this
# is usually an ngrok URL; in prod it's your Rails app's public HTTPS URL.
WEBHOOK_BASE_URL=

# ─── Integrations: Composio ──────────────────────────────────────────────────
# Get from https://app.composio.dev → Developers → API Keys. Required for
# the /integrations OAuth flow and for the engine to load third-party tools.
# After setting this, configure each toolkit's auth_config in the Composio
# dashboard (e.g. Gmail → "Set up auth"). Run `bin/rails integrations:check`
# to verify.
COMPOSIO_API_KEY=

# ─── Channels (optional) ─────────────────────────────────────────────────────
# Twilio — required for WhatsApp + SMS channels.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# AWS SES — required for agent email channel (inbound + outbound).
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Uploads ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ─── Observability (optional) ────────────────────────────────────────────────
# Server-side error + performance monitoring (Rails + Sidekiq).
SENTRY_DSN=
# Browser-side errors from the Inertia/React app. Prefer a separate Sentry
# project (DSNs are public — safe to expose to the client). Leave blank to
# disable; if you only have one project, set it to the same value as SENTRY_DSN.
SENTRY_FRONTEND_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.0
BETTERSTACK_SOURCE_TOKEN=

# ─── Analytics (optional — all client-side + public) ─────────────────────────
# Injected into the page at request time by AnalyticsHelper, so changing these
# takes effect without rebuilding assets. Leave a value blank to disable that
# provider. Nothing here loads under RAILS_ENV=test.
#
# Plausible — the site domain you registered in Plausible (e.g. double.md).
PLAUSIBLE_DOMAIN=
# Override only for self-hosted / proxied Plausible installs.
# PLAUSIBLE_SRC=https://plausible.io/js/script.js
# Google Analytics 4 measurement id (format: G-XXXXXXXXXX).
GA_MEASUREMENT_ID=
# PostHog product analytics — project API key (phc_...) + ingest host
# (https://us.i.posthog.com or https://eu.i.posthog.com).
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─── Sidekiq ─────────────────────────────────────────────────────────────────
SIDEKIQ_CONCURRENCY=5

# ─── AI Providers ───────────────────────────────────────────────────────────
# Anthropic
ANTHROPIC_API_KEY=sk-ant-*******
# OpenRouter (used by WebsiteAnalysisJob)
OPENROUTER_API_KEY=sk-or-*******
# Cloudflare (DNS auto-config; Browser Rendering crawl needs account ID too)
CLOUDFLARE_API_KEY=********
CLOUDFLARE_ACCOUNT_ID=

GOOGLE_OAUTH_CLIENT_ID=********
GOOGLE_OAUTH_CLIENT_SECRET=********