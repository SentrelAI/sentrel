# Alchemy Rails — example environment file.
# Copy to `.env` and fill in the values relevant for your environment.

# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost:5432/alchemy_development
REDIS_URL=redis://localhost:6379/0
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=info
PORT=3200

# Shared secret used to encode agt_/tsk_/cnv_ public_ids (prefixed_ids gem).
# Falls back to Rails.application.secret_key_base if unset. For production,
# set this to a dedicated random 32+ char value so the encoding is stable
# across secret_key_base rotations.
PREFIXED_IDS_SALT=

# ─── Engine bridge ───────────────────────────────────────────────────────────
# URL of the running alchemy_engine gateway (per-agent HTTP + WebSocket).
ENGINE_URL=http://localhost:3300

# Shared secret between Rails and engine for /api/blobs, /api/task_events,
# and EngineSync POST /sync. Must match ENGINE_API_SECRET in engine `.env`.
ENGINE_API_SECRET=

# Public base URL used when registering webhooks (Twilio, SES). In dev this
# is usually an ngrok URL; in prod it's your Rails app's public HTTPS URL.
WEBHOOK_BASE_URL=

# ─── Integrations: Composio ──────────────────────────────────────────────────
# Get from https://app.composio.dev → Developers → API Keys. Required for
# the /integrations OAuth flow and for the engine to load third-party tools.
# After setting this, configure each toolkit's auth_config in the Composio
# dashboard (e.g. Gmail → "Set up auth"). Run `bin/rails integrations:check`
# to verify.
COMPOSIO_API_KEY=

# ─── Channels (optional) ─────────────────────────────────────────────────────
# Twilio — required for WhatsApp + SMS channels.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# AWS SES — required for agent email channel (inbound + outbound).
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Uploads ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ─── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.0
BETTERSTACK_SOURCE_TOKEN=

# ─── Sidekiq ─────────────────────────────────────────────────────────────────
SIDEKIQ_CONCURRENCY=5
