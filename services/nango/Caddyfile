# Host-based routing for the Nango app. fly-proxy terminates TLS and forwards
# every hostname to Caddy on :8080.
#
#   nango-admin.sentrel.ai + sentrel-nango.fly.dev → the ADMIN DASHBOARD
#       (the Nango server's own SPA on :3003 — login, integrations, connections)
#   connect.sentrel.ai                              → the end-user CONNECT UI
#       (static SPA) + the API (by path → :3003)
{
	auto_https off
	admin off
}

:8080 {
	# fly-proxy terminates TLS then forwards plain HTTP to Caddy, so Caddy would
	# otherwise tell the Nango server X-Forwarded-Proto: http → req.secure=false
	# → broken session cookies. Force https (the app is only reachable via the
	# TLS fly-proxy) so Nango sets secure, same-site cookies correctly.
	@admin host nango-admin.sentrel.ai sentrel-nango.fly.dev
	handle @admin {
		reverse_proxy localhost:3003 {
			header_up X-Forwarded-Proto https
		}
	}

	# ── Connect UI host (connect.sentrel.ai + anything else) ──
	# Inverted routing: serve ONLY the static Connect UI SPA shell (root + its
	# assets) from disk; route EVERYTHING ELSE — the API (/connect, /connection,
	# /proxy, /oauth, /providers, …) AND WebSocket upgrades — to the Nango
	# server. This avoids whack-a-mole on individual API paths (a missing one
	# silently 200s the SPA HTML and breaks the call).

	# WebSocket upgrades (Nango's OAuth result channel) → server. Without this
	# the OAuth popup hangs blank: the SDK waits for the WS before navigating.
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @websocket {
		reverse_proxy localhost:3003 {
			header_up X-Forwarded-Proto https
		}
	}

	# Static SPA shell only.
	@connectui path / /assets/* /favicon.ico /fonts/* /images/* /locales/*
	handle @connectui {
		root * /app/nango/packages/connect-ui/dist
		try_files {path} /index.html
		file_server
	}

	# Everything else → the Nango server (API).
	handle {
		reverse_proxy localhost:3003 {
			header_up X-Forwarded-Proto https
		}
	}
}
