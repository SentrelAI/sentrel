<!DOCTYPE html>
<html>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 560px; margin: 0 auto; padding: 32px 24px; color: #1a1a1a;">
    <h1 style="font-size: 20px; margin: 0 0 16px;">New signup</h1>
    <p style="line-height: 1.6; color: #444;">
      A new user just signed up on Sentrel.
    </p>
    <table style="border-collapse: collapse; margin: 16px 0; font-size: 14px;">
      <tr>
        <td style="padding: 4px 12px 4px 0; color: #888;">Email</td>
        <td style="padding: 4px 0;"><strong><%= @user.email %></strong></td>
      </tr>
      <% if @user.name.present? %>
      <tr>
        <td style="padding: 4px 12px 4px 0; color: #888;">Name</td>
        <td style="padding: 4px 0;"><%= @user.name %></td>
      </tr>
      <% end %>
      <% if @organization %>
      <tr>
        <td style="padding: 4px 12px 4px 0; color: #888;">Organization</td>
        <td style="padding: 4px 0;"><%= @organization.name %></td>
      </tr>
      <% end %>
      <tr>
        <td style="padding: 4px 12px 4px 0; color: #888;">Source</td>
        <td style="padding: 4px 0;"><%= @source %></td>
      </tr>
      <tr>
        <td style="padding: 4px 12px 4px 0; color: #888;">Signed up</td>
        <td style="padding: 4px 0;"><%= @signed_up_at.strftime("%B %-d, %Y at %l:%M %p %Z") %></td>
      </tr>
    </table>
  </body>
</html>
