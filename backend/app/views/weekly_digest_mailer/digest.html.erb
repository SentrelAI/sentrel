<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 600px; margin: 0 auto; color: #1a1a1a;">
  <h2 style="font-size: 18px; margin-bottom: 4px;">Weekly Digest</h2>
  <p style="color: #666; font-size: 13px; margin-top: 0;">
    <%= @org.name %> &middot; <%= @week_start.strftime('%b %d') %> &ndash; <%= @week_end.strftime('%b %d, %Y') %>
  </p>

  <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
    <tr>
      <% [
        ["Messages", @totals[:messages]],
        ["Emails Sent", @totals[:emails]],
        ["Tasks Done", @totals[:tasks]],
        ["Approvals", @totals[:approvals]],
        ["Conversations", @totals[:conversations]],
        ["Errors", @totals[:errors]],
      ].each do |label, value| %>
        <td style="text-align: center; padding: 12px 8px; border: 1px solid #e5e5e5;">
          <div style="font-size: 22px; font-weight: 600;"><%= value %></div>
          <div style="font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.5px;"><%= label %></div>
        </td>
      <% end %>
    </tr>
  </table>

  <% if @per_agent.any? %>
    <h3 style="font-size: 14px; margin-bottom: 8px;">Per-Agent Breakdown</h3>
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
      <thead>
        <tr style="border-bottom: 2px solid #e5e5e5;">
          <th style="text-align: left; padding: 6px 8px;">Agent</th>
          <th style="text-align: right; padding: 6px 8px;">Messages</th>
          <th style="text-align: right; padding: 6px 8px;">Emails</th>
          <th style="text-align: right; padding: 6px 8px;">Tasks</th>
          <th style="text-align: right; padding: 6px 8px;">Errors</th>
        </tr>
      </thead>
      <tbody>
        <% @per_agent.each do |s| %>
          <tr style="border-bottom: 1px solid #f0f0f0;">
            <td style="padding: 6px 8px;">
              <strong><%= s[:agent].name %></strong>
              <span style="color: #888; font-size: 11px;"> &middot; <%= s[:agent].role %></span>
            </td>
            <td style="text-align: right; padding: 6px 8px;"><%= s[:messages] %></td>
            <td style="text-align: right; padding: 6px 8px;"><%= s[:emails] %></td>
            <td style="text-align: right; padding: 6px 8px;"><%= s[:tasks] %></td>
            <td style="text-align: right; padding: 6px 8px; <%= 'color: #ef4444;' if s[:errors] > 0 %>"><%= s[:errors] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <% if @pending_count > 0 %>
    <p style="margin-top: 20px; padding: 12px; background: #fef3c7; border-radius: 6px; font-size: 13px;">
      <strong><%= @pending_count %></strong> approval<%= @pending_count == 1 ? '' : 's' %> still pending review.
    </p>
  <% end %>

  <p style="margin-top: 24px; font-size: 12px; color: #999;">
    Sent by Sentrel &middot; <%= @org.name %>
  </p>
</div>
