# Copy to .kamal/secrets and fill in real values.
# NEVER commit .kamal/secrets — it's in .gitignore.

# Registry auth (GHCR via gh CLI token, or a dedicated PAT).
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# Rails master key (decrypts credentials.yml.enc).
RAILS_MASTER_KEY=$(cat config/master.key)

# Data stores.
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
REDIS_URL=rediss://host:6379

# App secrets.
ENGINE_API_SECRET=<32+ random chars>
PREFIXED_IDS_SALT=<32+ random chars>

# Integrations.
COMPOSIO_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Twilio (optional).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# AWS (SES + S3 + provisioning).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1

# Cloudflare (DNS auto-config + Browser Rendering crawl).
# API token needs Zone:DNS:Edit for zones you manage; Account ID for website crawl.
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Observability.
SENTRY_DSN=
# Browser-side Sentry for the React app (public DSN; separate project recommended).
SENTRY_FRONTEND_DSN=

# Analytics. PostHog project key (phc_...) — public, but kept here for parity.
# Non-secret analytics config (PLAUSIBLE_DOMAIN, GA_MEASUREMENT_ID, POSTHOG_HOST)
# lives in config/deploy.yml under env.clear.
POSTHOG_KEY=

# Engine provisioning.
AGENT_PROVISIONER=
DEPLOY_ENV=prod
WEBHOOK_BASE_URL=https://your-domain
RAILS_INTERNAL_URL=https://your-domain
