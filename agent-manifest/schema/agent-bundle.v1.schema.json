{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemy.scribemd.ai/schemas/agent-bundle.v1.schema.json",
  "title": "Agent Bundle manifest (agent.yaml)",
  "type": "object",
  "required": ["spec", "name"],
  "additionalProperties": false,
  "properties": {
    "spec": { "const": "agent-bundle/v1" },
    "name": { "type": "string", "minLength": 1 },
    "role": { "type": "string" },
    "description": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["starter", "sales", "support", "marketing", "engineering", "people", "personal", "ops"],
      "description": "Catalog category for the /templates gallery. One of the fixed set."
    },
    "icon": {
      "type": "string",
      "minLength": 1,
      "description": "Icon name (lucide-react) shown on the template card, e.g. \"Megaphone\", \"Wrench\", \"Calendar\"."
    },

    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mission"],
      "properties": {
        "mission": { "type": "string", "minLength": 1 },
        "kpis": {
          "type": "array",
          "items": {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "additionalProperties": { "type": "number" }
          }
        },
        "definition_of_done": { "type": "string" }
      }
    },

    "inputs": {
      "type": "array",
      "description": "Variables collected from the owner. Each renders as a form field; its value substitutes {{key}} tokens across persona, knowledge, schedules, and goal. `required` inputs block their stage until filled. `ask_at` picks the stage: the deploy wizard, or the post-deploy onboarding flow.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "placeholder": { "type": "string" },
          "type": {
            "enum": ["text", "list", "number", "boolean", "enum"],
            "default": "text",
            "description": "Data type. text → a single string. list → an array of strings, rendered into {{key}} as a newline bullet list. number. boolean. enum → one value chosen from `options`. Defaults to text."
          },
          "options": {
            "type": "array",
            "description": "Allowed choices. Required when type is enum; ignored for other types.",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "default": {
            "type": ["string", "number", "boolean", "array"],
            "description": "Pre-filled value. Must match the declared type, be one of `options` for enum, and satisfy `validate`.",
            "items": { "type": "string" }
          },
          "required": { "type": "boolean" },
          "ask_at": {
            "enum": ["deploy", "onboarding"],
            "default": "deploy",
            "description": "When the value is collected. deploy → the deploy wizard, before the agent exists. onboarding → the post-deploy onboarding flow, the first time the owner sets the agent up. Defaults to deploy."
          },
          "validate": {
            "type": "object",
            "additionalProperties": false,
            "description": "Constraints enforced on the value by the same ajv that validates the bundle. Applicable keys depend on type: text → pattern/min_length/max_length; number → min/max; list → min_items/max_items.",
            "properties": {
              "pattern": { "type": "string", "format": "regex" },
              "min_length": { "type": "integer", "minimum": 0 },
              "max_length": { "type": "integer", "minimum": 0 },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "min_items": { "type": "integer", "minimum": 0 },
              "max_items": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "enum" } }, "required": ["type"] },
            "then": { "required": ["options"] }
          }
        ]
      }
    },

    "persona": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "personality": { "$ref": "#/$defs/relativePath" },
        "identity": { "$ref": "#/$defs/relativePath" },
        "instructions": { "$ref": "#/$defs/relativePath" }
      }
    },

    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "id": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "thinking_level": { "enum": ["low", "medium", "high"] }
      }
    },

    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/relativePath" }
    },

    "builtin_skills": {
      "description": "Slugs of Sentrel built-in/platform skills the agent should have (e.g. web-search, send-email). Unlike `skills` (embedded SKILL.md bundles), these reference skills the runtime already provides, so no files are shipped.",
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
    },

    "capabilities": {
      "description": "Optional feature toggles for the deployed agent (knowledge_base, scheduling, tasks, integrations, recall, send_media). Each maps to an object like { enabled: true }. Omit to accept the platform defaults.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": { "enabled": { "type": "boolean" } }
      }
    },

    "knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "why": { "type": "string" }
        }
      }
    },

    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "config": { "$ref": "#/$defs/noSecretValues" },
          "why": { "type": "string" }
        }
      }
    },

    "schedules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "cron", "instruction"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "cron": { "type": "string", "minLength": 1 },
          "timezone": { "type": "string" },
          "instruction": { "type": "string", "minLength": 1 },
          "why": { "type": "string" }
        }
      }
    },

    "webhooks": {
      "type": "array",
      "description": "Inbound webhook endpoints created at deploy. Each gets a unique tokenized URL; external services POST to it and the agent runs the instruction against the payload immediately.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "instruction"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source": { "enum": ["generic", "github", "sentry", "linear", "stripe", "slack"] },
          "instruction": { "type": "string", "minLength": 1 },
          "why": { "type": "string" }
        }
      }
    },

    "integrations": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["service"],
            "properties": {
              "service": { "type": "string", "minLength": 1 },
              "required": {
                "type": "boolean",
                "description": "When true, deploy UIs must block deploying until this service is connected. Default false: connect now or after deploy."
              },
              "why": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["any_of"],
            "properties": {
              "any_of": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string", "minLength": 1 }
              },
              "multi": {
                "type": "boolean",
                "description": "false (default): pick exactly ONE alternative (e.g. one calendar). true: connect ANY NUMBER — the agent uses every connected one (e.g. post to all connected social networks)."
              },
              "required": {
                "type": "boolean",
                "description": "When true, deploy UIs block deploying until the requirement is met — the chosen alternative for a pick-one group, or at least one connected option for a multi group."
              },
              "why": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "name"],
            "properties": {
              "type": { "const": "mcp" },
              "name": { "type": "string", "minLength": 1 },
              "transport": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind"],
                "properties": {
                  "kind": { "enum": ["http", "sse", "stdio"] },
                  "url": { "type": "string", "format": "uri" },
                  "command": { "type": "string" }
                }
              },
              "why": { "type": "string" }
            }
          }
        ]
      }
    },

    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "why": { "type": "string" }
        }
      }
    },

    "permissions": {
      "type": "object",
      "additionalProperties": { "enum": ["block", "ask", "auto"] }
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "pattern": "^\\./",
      "not": { "pattern": "\\.\\." },
      "description": "Relative path inside the bundle. Must start with ./ and may not traverse upward."
    },
    "noSecretValues": {
      "type": "object",
      "propertyNames": {
        "not": {
          "pattern": "(token|secret|password|api_?key|private_key)"
        }
      },
      "description": "Lowercase fast-path only; the validator performs the authoritative case-insensitive deep scan."
    }
  }
}
