{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemy.scribemd.ai/schemas/agent-bundle.v1.schema.json",
  "title": "Agent Bundle manifest (agent.yaml)",
  "type": "object",
  "required": ["spec", "name"],
  "additionalProperties": false,
  "properties": {
    "spec": { "const": "agent-bundle/v1" },
    "name": { "type": "string", "minLength": 1 },
    "role": { "type": "string" },
    "description": { "type": "string" },

    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mission"],
      "properties": {
        "mission": { "type": "string", "minLength": 1 },
        "kpis": {
          "type": "array",
          "items": {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "additionalProperties": { "type": "number" }
          }
        },
        "definition_of_done": { "type": "string" }
      }
    },

    "inputs": {
      "type": "array",
      "description": "Deploy-time parameters. Deploy UIs render each as a form field; the value substitutes {{key}} tokens across persona, knowledge, schedules, and goal. required inputs block deploy until filled.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "placeholder": { "type": "string" },
          "default": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },

    "persona": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "personality": { "$ref": "#/$defs/relativePath" },
        "identity": { "$ref": "#/$defs/relativePath" },
        "instructions": { "$ref": "#/$defs/relativePath" }
      }
    },

    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "id": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "thinking_level": { "enum": ["low", "medium", "high"] }
      }
    },

    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/relativePath" }
    },

    "knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "why": { "type": "string" }
        }
      }
    },

    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "config": { "$ref": "#/$defs/noSecretValues" },
          "why": { "type": "string" }
        }
      }
    },

    "schedules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "cron", "instruction"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "cron": { "type": "string", "minLength": 1 },
          "timezone": { "type": "string" },
          "instruction": { "type": "string", "minLength": 1 },
          "why": { "type": "string" }
        }
      }
    },

    "webhooks": {
      "type": "array",
      "description": "Inbound webhook endpoints created at deploy. Each gets a unique tokenized URL; external services POST to it and the agent runs the instruction against the payload immediately.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "instruction"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source": { "enum": ["generic", "github", "sentry", "linear", "stripe", "slack"] },
          "instruction": { "type": "string", "minLength": 1 },
          "why": { "type": "string" }
        }
      }
    },

    "integrations": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["service"],
            "properties": {
              "service": { "type": "string", "minLength": 1 },
              "required": {
                "type": "boolean",
                "description": "When true, deploy UIs must block deploying until this service is connected. Default false: connect now or after deploy."
              },
              "why": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["any_of"],
            "properties": {
              "any_of": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string", "minLength": 1 }
              },
              "required": {
                "type": "boolean",
                "description": "When true, deploy UIs must block deploying until at least one alternative (the chosen one) is connected."
              },
              "why": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "name"],
            "properties": {
              "type": { "const": "mcp" },
              "name": { "type": "string", "minLength": 1 },
              "transport": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind"],
                "properties": {
                  "kind": { "enum": ["http", "sse", "stdio"] },
                  "url": { "type": "string", "format": "uri" },
                  "command": { "type": "string" }
                }
              },
              "why": { "type": "string" }
            }
          }
        ]
      }
    },

    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "why": { "type": "string" }
        }
      }
    },

    "permissions": {
      "type": "object",
      "additionalProperties": { "enum": ["block", "ask", "auto"] }
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "pattern": "^\\./",
      "not": { "pattern": "\\.\\." },
      "description": "Relative path inside the bundle. Must start with ./ and may not traverse upward."
    },
    "noSecretValues": {
      "type": "object",
      "propertyNames": {
        "not": {
          "pattern": "(token|secret|password|api_?key|private_key)"
        }
      },
      "description": "Lowercase fast-path only; the validator performs the authoritative case-insensitive deep scan."
    }
  }
}
